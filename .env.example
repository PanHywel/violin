# ── API keys ─────────────────────────────────────────────────
# Only fill in the keys for the providers you actually use — see
# config/default.yaml `models:` section. The default DeepSeek + Volcengine stack
# needs DEEPSEEK_API_KEY plus the Volcengine ASR/TTS variables below.

# DeepSeek — needed when translation uses `provider: deepseek`
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Volcengine ASR — needed when transcription uses `provider: volcengine`
VOLCENGINE_ASR_APP_KEY=
# VOLCENGINE_ASR_ACCESS_TOKEN=              # old console only
VOLCENGINE_ASR_RESOURCE_ID=volc.bigasr.auc
VOLCENGINE_ASR_BASE_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit
# VOLCENGINE_ASR_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query

# Volcengine TTS — needed when TTS uses `provider: volcengine`
VOLCENGINE_TTS_API_KEY=
VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0
# VOLCENGINE_TTS_BASE_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
# VOLCENGINE_TTS_VOICE_TYPE=


# ── Optional legacy/alternate providers ───────────────────────

# Together AI — https://api.together.ai
TOGETHER_API_KEY=

# OpenAI — needed when any stage uses `provider: openai`
# (whisper-1, GPT models, tts-1, vision chat). https://platform.openai.com
OPENAI_API_KEY=

# ElevenLabs — needed when TTS uses `provider: elevenlabs`
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=


# ── Optional ─────────────────────────────────────────────────

# CORS allow-list for the web app (default: * — any origin)
# CORS_ORIGINS=https://yourdomain.com
